{
  "version": 2,
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "dist/public/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "dist/boot.js"
    },
    {
      "src": "/(.*)",
      "dest": "dist/boot.js"
    }
  ]
}
